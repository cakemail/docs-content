  "regional_notes": {
    "fr-CA": {
      "description": "French Canadian terminology differs from French France primarily in technology terms",
      "key_differences": [
        "email → courriel (instead of email)",
        "spam → pourriel (instead of spam)",
        "template → gabarit (instead of modèle)",
        "landing page → page de destination (instead of page d'atterrissage)",
        "opt-in → abonnement (instead of inscription)"
      ],
      "usage_notes": "French Canadian tends to avoid anglicisms more than French France"
    },
    "es": {
      "description": "Spanish email marketing terminology with regional variations across Latin America",
      "key_differences": [
        "newsletter → boletín informativo/electrónico (instead of newsletter)",
        "email → correo electrónico (formal) vs email (informal)",
        "consent → consentimiento (legal context)",
        "spam → spam (universally used)",
        "cold email → correo frío (newer term)"
      ],
      "usage_notes": "Legal terms like 'consentimiento' and 'protección de datos' are standardized across Spanish-speaking countries, but local privacy laws vary (LGPD in Brazil, PDPA in Argentina, Law 1581 in Colombia)",
      "regional_laws": {
        "brazil": "LGPD (Lei Geral de Proteção de Dados)",
        "argentina": "PDPA (Personal Data Protection Act 25.326)",
        "colombia": "Law 1581 of 2012",
        "mexico": "Personal Data Protection Law",
        "spain": "RGPD + LOPDGDD"
      }
    }
  },
